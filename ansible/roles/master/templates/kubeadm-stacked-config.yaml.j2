apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
bootstrapTokens:
  - groups:
    - system:bootstrappers:kubeadm:default-node-token
    token: {{ random_token }}
    ttl: 24h0m0s
    usages:
    - signing
    - authentication
localAPIEndpoint:
  advertiseAddress: "{{ hostvars[inventory_hostname].ip }}"
certificateKey: {{ certificate_key }} 
nodeRegistration:
  criSocket: unix:///var/run/containerd/containerd.sock
  imagePullPolicy: IfNotPresent
  kubeletExtraArgs:
    - name: "node-ip"
      value: "{{ hostvars[inventory_hostname].ip }}"
    - name: "address"
      value: "{{ hostvars[inventory_hostname].ip }}"
  taints:
  - key: "node-role.kubernetes.io/control-plane"
    value: "false"
    effect: "NoSchedule"
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
controllerManager:
  extraArgs:
    - name: "concurrent-deployment-syncs"
      value: "10"
    - name: "concurrent-endpoint-syncs"
      value: "10"
apiServer:
  extraArgs:
    - name: "max-requests-inflight"
      value: "400" # Up from default 200 read requests
    - name: "max-mutating-requests-inflight"
      value: "200" # Up from default 100 write requests
    - name: "audit-log-path"
      value: "/var/log/kubernetes/audit.log"
    - name: "audit-log-maxage"
      value: "30"
    - name: "audit-log-maxbackup"
      value: "10"
    - name: "audit-log-maxsize"
      value: "100"
  extraVolumes:
    - name: audit-logs
      hostPath: /var/log/kubernetes
      mountPath: /var/log/kubernetes
      readOnly: false
      
  certSANs:
    - "{{ loadbalancer_apiserver }}"
    - "127.0.0.1"
    - "0.0.0.0"
  {% for ip in etcd_initial_cluster %}
  - "{{ ip }}"
  {% endfor %}

imageRepository: k8s.repo.gpkg.io
kubernetesVersion: "{{ kubernetes_version }}"
controlPlaneEndpoint: "{{ loadbalancer_apiserver }}:6443"
dns:
  imageRepository: k8s.repo.gpkg.io/coredns
networking:
  dnsDomain: cluster.local
  serviceSubnet: "{{ service_subnet }}"
  podSubnet: "{{ calico_network_calico_cidr }}"
etcd:
  local:
    extraArgs:
      - name: "quota-backend-bytes"
        value: "8589934592" # Increase DB size from 2GB to 8GB
      - name: "heartbeat-interval"
        value: "250"        # Allow 250ms for virtualized disk/network delays
      - name: "election-timeout"
        value: "1250"       # Corresponds to 5x the heartbeat interval
    serverCertSANs: 
    {% for ip in etcd_initial_cluster %}
      - {{ ip }}
    {% endfor %}

    peerCertSANs: 
    {% for ip in etcd_initial_cluster %}
      - {{ ip }}
    {% endfor %}

---
apiVersion: kubeproxy.config.k8s.io/v1alpha1
kind: KubeProxyConfiguration
mode: "ipvs"
ipvs:
  scheduler: "rr" # Round Robin