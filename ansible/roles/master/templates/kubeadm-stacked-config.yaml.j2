apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
bootstrapTokens:
  - groups:
    - system:bootstrappers:kubeadm:default-node-token
    token: {{ random_token }}
    ttl: 24h0m0s
    usages:
    - signing
    - authentication
localAPIEndpoint:
  advertiseAddress: "{{ hostvars[inventory_hostname].ip }}"
certificateKey: {{ certificate_key }} 
nodeRegistration:
  criSocket: unix:///var/run/containerd/containerd.sock
  imagePullPolicy: IfNotPresent
  kubeletExtraArgs:
    - name: "node-ip"
      value: "{{ hostvars[inventory_hostname].ip }}"
    - name: "address"
      value: "{{ hostvars[inventory_hostname].ip }}"
    - name: "max-pods"
      value: "250"
    - name: "kube-api-qps"
      value: "50"                          
    - name: "kube-api-burst"
      value: "100"
    - name: "cgroup-driver"
      value: "systemd"
    - name: "system-reserved"
      value: "cpu=100m,memory=256Mi,ephemeral-storage=1Gi"
    - name: "kube-reserved"
      value: "cpu=100m,memory=512Mi,ephemeral-storage=2Gi"
  taints:
  - key: "node-role.kubernetes.io/control-plane"
    value: "false"
    effect: "NoSchedule"
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
controllerManager:
  extraArgs:
    - name: "concurrent-deployment-syncs"
      value: "20"          # Increased from default 5
    - name: "concurrent-endpoint-syncs"
      value: "10"
    - name: "concurrent-replicaset-syncs"
      value: "5"
    - name: "concurrent-service-syncs"
      value: "3"
    - name: "concurrent-gc-syncs"
      value: "30"
apiServer:
  extraArgs:
    - name: "max-requests-inflight"
      value: "400" # Up from default 200 read requests
    - name: "max-mutating-requests-inflight"
      value: "200" # Up from default 100 write requests
    - name: "request-timeout"
      value: "300s"          # Prevent premature disconnects in virtualized environments
    - name: "shutdown-delay-duration"
      value: "15s"           # Graceful shutdown for in-flight requests
    - name: "tls-min-version"
      value: "VersionTLS12"  # Enforce minimum TLS 1.2
      
  certSANs:
    - "{{ loadbalancer_apiserver }}"
    - "127.0.0.1"
    - "0.0.0.0"
  {% for ip in etcd_initial_cluster %}
  - "{{ ip }}"
  {% endfor %}

imageRepository: k8s.repo.gpkg.io
kubernetesVersion: "{{ kubernetes_version }}"
controlPlaneEndpoint: "{{ loadbalancer_apiserver }}:6443"
dns:
  imageRepository: k8s.repo.gpkg.io/coredns
networking:
  dnsDomain: cluster.local
  serviceSubnet: "{{ service_subnet }}"
  podSubnet: "{{ calico_network_calico_cidr }}"
etcd:
  local:
    extraArgs:
      - name: "quota-backend-bytes"
        value: "8589934592" # Increase DB size from 2GB to 8GB
      - name: "heartbeat-interval"
        value: "250"        # Allow 250ms for virtualized disk/network delays
      - name: "election-timeout"
        value: "1250"       # Corresponds to 5x the heartbeat interval
      - name: "snapshot-count"
        value: "20000"      # Reduce compaction frequency for Proxmox disk latency
      - name: "max-request-bytes"
        value: "33554432"   # 32MB to allow larger object sizes
      - name: "auto-compaction-retention"
        value: "1h"         # Prevent database bloat
    serverCertSANs: 
    {% for ip in etcd_initial_cluster %}
      - {{ ip }}
    {% endfor %}

    peerCertSANs: 
    {% for ip in etcd_initial_cluster %}
      - {{ ip }}
    {% endfor %}

---
apiVersion: kubeproxy.config.k8s.io/v1alpha1
kind: KubeProxyConfiguration
mode: "ipvs"
ipvs:
  scheduler: "rr" # Round Robin