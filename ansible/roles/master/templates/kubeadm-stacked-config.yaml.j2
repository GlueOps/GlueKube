apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
bootstrapTokens:
  - groups:
    - system:bootstrappers:kubeadm:default-node-token
    token: {{ random_token }}
    ttl: 24h0m0s
    usages:
    - signing
    - authentication
localAPIEndpoint:
  advertiseAddress: "{{ hostvars[inventory_hostname].ip }}"
certificateKey: {{ certificate_key }} 
nodeRegistration:
  criSocket: unix:///var/run/containerd/containerd.sock
  kubeletExtraArgs:
    - name: "node-ip"
      value: "{{ hostvars[inventory_hostname].ip }}"
  imagePullPolicy: IfNotPresent
  taints:
  - key: "node-role.kubernetes.io/control-plane"
    value: "false"
    effect: "NoSchedule"
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
apiServer:
  certSANs:
    - "{{ loadbalancer_apiserver }}"
    - "127.0.0.1"
    - "0.0.0.0"
  {% for ip in etcd_initial_cluster %}
  - "{{ ip }}"
  {% endfor %}

imageRepository: k8s.repo.gpkg.io
kubernetesVersion: "{{ kubernetes_version }}"
controlPlaneEndpoint: "{{ loadbalancer_apiserver }}:6443"
dns:
  imageRepository: k8s.repo.gpkg.io/coredns
networking:
  dnsDomain: cluster.local
  serviceSubnet: "{{ service_subnet }}"
  podSubnet: "{{ calico_network_calico_cidr }}"
etcd:
  local:
    serverCertSANs: 
    {% for ip in etcd_initial_cluster %}
      - {{ ip }}
    {% endfor %}

    peerCertSANs: 
    {% for ip in etcd_initial_cluster %}
      - {{ ip }}
    {% endfor %}

---
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
address: "{{ hostvars[inventory_hostname].ip }}"
cgroupDriver: systemd
enforceNodeAllocatable:
  - pods
  - system-reserved
  - kube-reserved
kubeReserved:
  cpu: "150m"
  memory: "500Mi"
systemReserved:
  cpu: "150m"
  memory: "500Mi"
evictionHard:
  memory.available: "300Mi"
  nodefs.available: "10%"
  nodefs.inodesFree: "5%"
  imagefs.available: "15%"